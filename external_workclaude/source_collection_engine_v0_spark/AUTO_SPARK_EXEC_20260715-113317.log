                "attempted": False,
                "success": False,
                "count": 0,
                "error_message": "",
                "failed_reason": "",
                "fallback_reason": "",
                "collection_method": "",
                "used_cache": False,
                "cache_path": str(self.nate_pann_cache_path).replace("\\", "/"),
                "retry_enabled": self.retry_policy.enabled,
                "retry_count": 0,
                "cache_age_seconds": None,
                "cache_expired": False,
                "service_diagnostic": {
                    "service": "nate_pann",
                    "status": "ok",
                    "error_type": "",
                    "safe_message": "",
                    "api_key_present": None,
                },
            },
            "fmkorea": {
                "source": "fmkorea",
