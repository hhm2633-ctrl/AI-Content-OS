                    {
                        "source_id": "news_c",
                        "lane_impact": ["news_lane"],
                        "status": STATUS_FALLBACK_ONLY,
                    }
                ],
                STATUS_FAILED: [
                    {
                        "source_id": "news_d",
                        "lane_impact": ["daily_lane"],
                        "status": STATUS_FAILED,
                    },
                ],
