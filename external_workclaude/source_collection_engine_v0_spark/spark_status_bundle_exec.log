    def test_fake_gap_report_builds_counts_readiness_and_ordering(self):
        gap_report = {
            "status_summary": {
                STATUS_NOT_IMPLEMENTED: [
                    {
                        "source_id": "news_a",
                        "lane_impact": ["news_lane", "daily_lane"],
                        "status": STATUS_NOT_IMPLEMENTED,
                    },
