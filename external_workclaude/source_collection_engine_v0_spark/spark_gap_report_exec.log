+                    "collection_method": "settings_keyword_fallback",
+                    "is_fallback": True,
+                },
+                {
+                    "source_id": "news_a",
+                    "source_type": "news",
+                    "collection_method": "settings_keyword_fallback",
+                    "is_fallback": True,
+                },
+            ],
