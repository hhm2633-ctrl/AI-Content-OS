+                {
+                    "source_id": "news_c",
+                    "lane_id": "news_society_economy",
+                    "attempted": False,
+                    "success": False,
+                    "skipped": True,
+                    "skip_reason": "collector_not_implemented",
+                    "count": 0,
+                },
+                {
+                    "source_id": "community_d",
+                    "attempted": False,
+                    "success": False,
