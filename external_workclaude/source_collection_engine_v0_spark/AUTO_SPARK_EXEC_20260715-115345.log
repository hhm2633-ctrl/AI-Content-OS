+    def _extract_article_id(self, url: str) -> str:
+        match = re.search(r"/(\d{19})(?:/|$)", url)
+        if match:
+            return match.group(1)
+
+        parsed = urllib.parse.urlparse(url)
+        if "mtview.php" in parsed.path:
