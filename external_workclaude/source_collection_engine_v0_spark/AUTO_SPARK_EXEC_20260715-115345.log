        re.compile(r"(?i)bearer\s+[A-Za-z0-9_\-\.]{8,}"),
        re.compile(r"(?i)(api[_-]?key\s*[:=]\s*)([^\s,;'\"]{4,})"),
        re.compile(r"(?i)(token\s*[:=]\s*)([^\s,;'\"]{4,})"),
        re.compile(r"(?i)(password\s*[:=]\s*)([^\s,;'\"]{4,})"),
    )

    def __init__(self, config: Optional[Dict[str, Any]] = None):
