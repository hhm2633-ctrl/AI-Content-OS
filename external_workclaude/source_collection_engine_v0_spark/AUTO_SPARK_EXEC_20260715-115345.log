+            "parse_failed",
+            "parse_error",
+            "no_results",
+            "empty_result",
+            "unknown_error",
+        ]
+        reasons = [item.get("reason", "unknown_error") for item in errors]
+
+        for reason in priority:
+            if reason in reasons:
+                return reason
+
+        return reasons[0] if reasons else "unknown_error"
