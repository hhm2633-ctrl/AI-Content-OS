        result = run_collection_gap_report(
            collection_result_path=input_path,
            today="2026-07-14",
            output_root=work_root,
        )

        for entry in result["implementation_queue"]:
            self.assertNotIn("commerce_detail", entry)


if __name__ == "__main__":
