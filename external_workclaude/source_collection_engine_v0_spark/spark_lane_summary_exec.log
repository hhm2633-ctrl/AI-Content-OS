+    for lane_id in lanes:
+        lane_summary[lane_id] = {
+            "counts_by_status": _coerce_counts_dict(),
+            "top_missing_sources": [],
+            "lane_readiness": None,
+        }
+
+    for status in SUMMARY_STATUSES:
+        entries = status_summary.get(status, [])
