+            continue
+        for entry in entries:
+            if not isinstance(entry, dict):
+                continue
+            source_id = entry.get("source_id")
+            if not isinstance(source_id, str):
+                continue
+            impacted_lanes = _to_list(entry.get("lane_impact"))
