      "published_at": "2026-07-15T09:31:00+09:00",
      "collected_at": "2026-07-15T10:20:00+09:00",
      "list_type": "category",
      "category_path": ["증권", "증권뉴스", "종목"],
      "category_slug": "stock",
      "reporter": "홍길동 기자",
      "reporter_id": "sample",
      "publisher": "이데일리"
    }
  ]
}
