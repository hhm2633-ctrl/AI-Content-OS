{
  "contract_name": "dcinside_list_fixture",
  "version": "1.0",
  "verified_at": "2026-07-15",
  "source": {
    "site": "dcinside",
    "surface": "board_list",
    "canonical_url_template": "https://gall.dcinside.com/board/lists/?id={board_id}&page={page}",
    "recommended_board_id": "dcbest",
    "rendering": "server_rendered_html",
    "encoding": "utf-8",
    "robots_policy": "AI crawlers (ClaudeBot/anthropic-ai/GPTBot etc.) disallowed site-wide on gall.dcinside.com; generic UA allowed except listed boards. Live collection requires explicit owner policy decision; default to fixture/cache-only."
  },
  "parse": {
    "row_selector": "table.gall_list tbody tr.ub-content.us-post",
    "skip_row_classes_absent": ["us-post"],
    "fields": {
      "post_no": {"selector": "tr@data-no", "type": "string"},
      "post_type": {"selector": "tr@data-type", "type": "string", "examples": ["icon_txt", "icon_pic", "icon_recomtxt", "icon_recomimg", "icon_btimebest", "icon_hit"]},
      "title": {"selector": "td.gall_tit > a:first-child (text, minus strong prefix)", "type": "string"},
      "origin_board_tag": {"selector": "td.gall_tit strong", "type": "string|null", "note": "dcbest only, e.g. [해갤]; strip brackets"},
      "url": {"selector": "td.gall_tit > a:first-child@href", "type": "string", "note": "relative; join with https://gall.dcinside.com"},
      "posted_at": {"selector": "td.gall_date@title", "type": "string", "format": "YYYY-MM-DD HH:MM:SS", "note": "never use visible text (ambiguous short form)"},
      "views": {"selector": "td.gall_count", "type": "int"},
      "recommends": {"selector": "td.gall_recommend", "type": "int"},
      "comments": {"selector": "td.gall_tit a.reply_numbox span.reply_num", "type": "int", "note": "strip brackets; on 'N/M' take N"},
      "rank": {"selector": null, "type": "int", "note": "1-based order of us-post rows on page 1"}
    },
    "sanitization": {
      "drop": ["data-nick", "data-uid", "data-ip", "thumbnail_url", "nickname icon markup"],
      "reason": "author identity and media not needed for trend ranking; keep only public aggregate signals"
    }
  },
  "record_schema": {
    "type": "object",
    "required": ["source", "board_id", "post_no", "title", "url", "posted_at", "rank"],
    "properties": {
      "source": {"const": "dcinside"},
      "board_id": {"type": "string"},
      "post_no": {"type": "string"},
      "title": {"type": "string", "minLength": 1},
      "origin_board_tag": {"type": ["string", "null"]},
      "url": {"type": "string", "pattern": "^https://gall\\.dcinside\\.com/board/view/"},
      "posted_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"},
      "views": {"type": "integer", "minimum": 0},
      "recommends": {"type": "integer", "minimum": 0},
      "comments": {"type": "integer", "minimum": 0},
      "rank": {"type": "integer", "minimum": 1},
      "collected_at": {"type": "string", "format": "date-time"}
    }
  },
  "sample_records": [
    {
      "source": "dcinside",
      "board_id": "dcbest",
      "post_no": "445680",
      "title": "여자들도 눈물. 아이사랑두. 호날두 국내에서 민심 최고조이던 시절. ㄷ",
      "origin_board_tag": "해갤",
      "url": "https://gall.dcinside.com/board/view/?id=dcbest&no=445680",
      "posted_at": "2026-07-15 00:00:00",
      "views": 12345,
      "recommends": 100,
      "comments": 21,
      "rank": 1,
      "collected_at": "2026-07-15T03:00:00+09:00"
    }
  ],
  "fixture_rules": {
    "min_records": 10,
    "pinned_rows_excluded": true,
    "adult_or_restricted_boards": "never included",
    "field_values": "sanitized/representative, not verbatim dumps of personal data"
  },
  "fallback_chain_note": "Per AI-Content-OS fallback-first contract: live collect -> retry -> cache -> settings keyword fallback -> hardcoded placeholder; fixture files must satisfy this schema so cache path stays valid."
}
