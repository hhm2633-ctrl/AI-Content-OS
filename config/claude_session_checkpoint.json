{
  "schema_version": "claude_session_checkpoint_config_v1",
  "enabled": false,
  "automatic_hooks_enabled": false,
  "owner_approved": false,
  "activation_note": "Keep disabled until Claude C18 and Spark SC finish and the owner explicitly approves activation. Do not edit .claude/settings.local.json from this work order.",
  "accepted_events": [
    "assignment",
    "complete",
    "blocked",
    "precompact",
    "session_start",
    "session_end"
  ],
  "allowed_metadata_fields": [
    "session_id",
    "occurred_at",
    "task_id",
    "task_name",
    "lane_id",
    "agent_id",
    "status",
    "reason_code",
    "note",
    "next_action",
    "owned_files",
    "changed_files",
    "blocker_codes"
  ],
  "maximum_list_items": 40,
  "maximum_record_bytes": 16384,
  "history_path": "storage/session_checkpoints/claude_session_events.jsonl",
  "latest_path": "storage/session_checkpoints/claude_session_latest.json"
}
