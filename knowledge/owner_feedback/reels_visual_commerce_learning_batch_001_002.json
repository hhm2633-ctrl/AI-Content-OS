  "owner_direction": "Retain both owner-confirmed corrections and assistant-observed patterns because each may become useful in later production.",
  "shared_patterns": {
    "layout": [
      "Reserve roughly the upper 20-30 percent for a short hook when the footage is visually busy.",
      "Keep the primary footage or person dominant and place product cards in available edge space.",
      "Use a white editorial frame for explanatory, community-post, or source-context content.",
      "Use black framing for curiosity, conflict, comparison, entertainment, gaming, and transformation hooks.",
      "Treat the product as a separate sticker card with white border, slight tilt, and shadow instead of merging it into factual footage."
    ],
    "color": [
      "Use black or white as the stable base with one semantic accent color.",
      "Yellow commonly marks curiosity, reason, surprise, or the key noun.",
      "Blue or cyan supports gaming, technology, coolness, or explanatory contrast.",
      "Red or pink supports conflict, celebrity, fashion, stage, or emotional emphasis.",
      "Neon green supports beauty, transformation, or playful visual contrast."
    ],
    "typography": [
      "Prefer a heavy condensed sans headline of one or two lines.",
      "Color only the decisive keyword rather than the whole title.",
      "Use stroke or shadow only where text overlays footage.",
      "Keep scene subtitles to one short sentence and separate quotations or comments into a bar."
    ],
    "hook": [
      "why_or_reason",
      "unexpected_fact",
      "reveal_or_secret",
      "comparison_or_matchup",
      "incident_or_conflict",
      "transformation",
      "strange_or_absurd_scene",
      "nostalgia_or_archive"
    ],
    "commerce": [
      "Generate direct product, activity tool, visible accessory, same-style item, fandom item, scene-function item, visual-similarity item, adjacent item, and wordplay item as separate candidates.",
      "Do not force a single product when several understandable bridges exist.",
      "Preserve the explanation and relation type for every indirect candidate.",
      "A playful association is usable when viewers can immediately understand it and it does not interrupt the content flow."
    ]
  },
