.env

__pycache__/
*.pyc

storage/**
!storage/
!storage/README.md
!storage/cache/
!storage/cache/.gitkeep
!storage/history/
!storage/history/.gitkeep
!storage/logs/
!storage/logs/.gitkeep
!storage/memory/
!storage/memory/.gitkeep
!storage/planner/
!storage/planner/.gitkeep
!storage/topics/
!storage/topics/.gitkeep
!storage/trends/
!storage/trends/.gitkeep

# Explicit runtime-output call-outs (Sprint 5). Already covered by the
# storage/** blanket rule above; kept explicit here for readability/auditing
# so it's obvious at a glance which runtime outputs are never git-tracked.
storage/content/
storage/llm_logs/
storage/trends/snapshots/
storage/workflow_results/
storage/generated_images/
storage/card_news/
storage/images/

logs/

# Regenerable / externalized (2026-07-20)
tools/cardnews-renderer/node_modules/
graphify-out/

